<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Analytics Educators</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: 'Segoe UI', sans-serif;
}

body{
  background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
  color:white;
  min-height:100vh;
}

header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 8%;
}

.logo{
  font-size:22px;
  font-weight:bold;
  letter-spacing:1px;
}

nav a{
  color:white;
  text-decoration:none;
  margin-left:20px;
  font-size:15px;
  transition:0.3s;
}

nav a:hover{
  color:#00f5d4;
}

.hero{
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  height:80vh;
  padding:20px;
}

.hero h1{
  font-size:42px;
  margin-bottom:15px;
}

.hero p{
  font-size:18px;
  max-width:600px;
  margin-bottom:25px;
  opacity:0.85;
}

.btn{
  padding:12px 28px;
  border:none;
  background:#00f5d4;
  color:black;
  font-weight:bold;
  border-radius:25px;
  cursor:pointer;
  transition:0.3s;
}

.btn:hover{
  transform:scale(1.05);
  background:white;
}

.section{
  padding:60px 8%;
  text-align:center;
}

.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:25px;
  margin-top:40px;
}

.card{
  background:rgba(255,255,255,0.1);
  padding:25px;
  border-radius:15px;
  backdrop-filter:blur(10px);
  transition:0.3s;
}

.card:hover{
  transform:translateY(-8px);
}

footer{
  text-align:center;
  padding:20px;
  background:rgba(0,0,0,0.3);
  margin-top:40px;
}
</style>

</head>
<body>

<header>
  <div class="logo">Analytics Educators</div>
  <nav>
    <a href="#">Home</a>
    <a href="#">Courses</a>
    <a href="#">About</a>
    <a href="#">Contact</a>
  </nav>
</header>

<section class="hero">
  <h1>Learn Data. Build Future.</h1>
  <p>Master Excel Automation, Python, Machine Learning, Java and SQL with practical projects and industry-focused training.</p>
  <button class="btn" onclick="enroll()">Explore Courses</button>
</section>

<section class="section">
  <h2>Our Popular Courses</h2>
  <div class="cards">
    <div class="card">
      <h3>Python Programming</h3>
      <p>From basics to advanced automation and real-world projects.</p>
    </div>
    <div class="card">
      <h3>Machine Learning</h3>
      <p>Build intelligent systems with supervised and unsupervised learning.</p>
    </div>
    <div class="card">
      <h3>Excel & SQL</h3>
      <p>Data analysis, dashboards, and database mastery.</p>
    </div>
  </div>
</section>

<footer>
  © 2026 Analytics Educators | All Rights Reserved
</footer>

<script>
function enroll(){
  alert("Enrollment feature coming soon 🚀");
}
</script>

</body>
</html>